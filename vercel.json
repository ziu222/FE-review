{
  "buildCommand": "npm run build:tw",
  "public": ".",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/customer/home.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/admin-login.html"
    },
    {
      "source": "/admin/dashboard",
      "destination": "/admin/dashboard.html"
    },
    {
      "source": "/admin/products",
      "destination": "/admin/products.html"
    },
    {
      "source": "/admin/orders",
      "destination": "/admin/orders-manage.html"
    },
    {
      "source": "/admin/shops",
      "destination": "/admin/shops-manage.html"
    },
    {
      "source": "/admin/users",
      "destination": "/admin/users-manage.html"
    },
    {
      "source": "/admin/finance",
      "destination": "/admin/finance-manage.html"
    },
    {
      "source": "/admin/notifications",
      "destination": "/admin/notifications.html"
    }
  ],
  "headers": [
    {
      "source": "/404.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
